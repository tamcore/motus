# Database configuration
MOTUS_DATABASE_HOST=localhost
MOTUS_DATABASE_PORT=5432
MOTUS_DATABASE_USER=motus
MOTUS_DATABASE_PASSWORD=motus
MOTUS_DATABASE_NAME=motus
MOTUS_DATABASE_SSLMODE=disable

# HTTP server
MOTUS_SERVER_PORT=8080

# GPS protocol listeners
MOTUS_GPS_H02_PORT=5013
MOTUS_GPS_WATCH_PORT=5093

# Optional: relay all H02 messages to another GPS server (e.g., Traccar)
# MOTUS_GPS_H02_RELAY_TARGET=traccar.example.com:5013

# Optional: relay all WATCH messages to another GPS server
# MOTUS_GPS_WATCH_RELAY_TARGET=traccar.example.com:5093

# OIDC Authentication (optional)
# MOTUS_OIDC_ENABLED=false
# MOTUS_OIDC_ISSUER=https://accounts.google.com
# MOTUS_OIDC_CLIENT_ID=your-client-id
# MOTUS_OIDC_CLIENT_SECRET=your-client-secret
# MOTUS_OIDC_REDIRECT_URL=https://motus.example.com/api/auth/oidc/callback
# MOTUS_OIDC_SIGNUP_ENABLED=false           # allow new account creation via OIDC
# MOTUS_OIDC_ADMIN_EMAIL_REGEX=@mycompany\.com$   # optional: regex to grant admin role
# MOTUS_OIDC_ADMIN_CLAIM=groups             # optional: claim key for admin check
# MOTUS_OIDC_ADMIN_CLAIM_VALUE=motus-admin  # optional: claim value that grants admin
# MOTUS_OIDC_SCOPES=                        # optional: extra scopes (space-separated)
